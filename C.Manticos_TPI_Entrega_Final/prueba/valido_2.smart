// Sistema de seguridad nocturno (Valido)
WHEN sensor_movimiento_patio == TRUE AND reloj.hora > 22:00 DO
    alarma_casa.activada = TRUE
    foco_patio.estado = ON
    foco_patio.brillo = 100%
    altavoz_alerta.mute = ON
    altavoz_alerta.volumen = 80%
END

WHEN sensor_humo_cocina == TRUE DO
    alarma_casa.activada = TRUE
    cerradura_principal.estado = OFF
    altavoz_alerta.mensaje = "Alerta de incendio detectada"
END
